AI_PROVIDER=huggingface

OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-5.4-mini

HF_API_KEY=hf_your_huggingface_token
HF_MODEL=google/gemma-2-2b-it

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_MODEL=@cf/openai/gpt-oss-20b

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:your-telegram-bot-token

# For reliable delivery to a personal Telegram account, use numeric chat_id.
# If you leave only TELEGRAM_TARGET=@SHAKOTAN2, Telegram may reject delivery
# for a private user chat until the bot has been started and a numeric chat_id is known.
TELEGRAM_CHAT_ID=
TELEGRAM_TARGET=@SHAKOTAN2

SITE_NAME=PrintForge 3D
HOST=127.0.0.1
PORT=8000

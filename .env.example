AI_PROVIDER=huggingface

OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-5.4-mini

HF_API_KEY=hf_your_huggingface_token
HF_MODEL=google/gemma-2-2b-it

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_MODEL=@cf/openai/gpt-oss-20b

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:1b

# Telegram bot for заявки from @BotFather
LEADS_TELEGRAM_BOT_TOKEN=123456789:your-leads-bot-token

# For reliable delivery to a personal Telegram account, use numeric chat_id.
# If you leave only LEADS_TELEGRAM_TARGET=@SHAKOTAN2, Telegram may reject delivery
# for a private user chat until the bot has been started and a numeric chat_id is known.
LEADS_TELEGRAM_CHAT_ID=
LEADS_TELEGRAM_TARGET=@SHAKOTAN2

# Optional backward-compatible aliases for older config
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TARGET=

# Telegram bot for clients. Replace after you create the second bot.
CLIENT_TELEGRAM_BOT_TOKEN=123456789:your-client-bot-token
CLIENT_TELEGRAM_BOT_URL=https://t.me/your_client_bot
CLIENT_TELEGRAM_BOT_LABEL=@your_client_bot

SITE_NAME=3d_design
HOST=127.0.0.1
PORT=8000

# Max contact upload size in bytes (default 10 MB)
MAX_UPLOAD_BYTES=10485760

# Set to 0 to disable built-in event analytics
INTERNAL_ANALYTICS_ENABLED=1

# Protects GET /api/metrics?token=...
METRICS_TOKEN=change-me
METRICS_HEADER_NAME=X-Metrics-Token
TRUST_PROXY_HEADERS=0
TRUSTED_PROXY_IPS=127.0.0.1,::1

# Optional: explicit allowed browser origins for POST requests.
# Leave empty to allow the current host origin automatically.
ALLOWED_ORIGINS=

# Limits for text fields
MAX_CHAT_MESSAGE_CHARS=2000
MAX_CONTACT_NAME_CHARS=100
MAX_CONTACT_FIELD_CHARS=120
MAX_TASK_CHARS=4000

# Allowed file extensions for contact uploads
ALLOWED_UPLOAD_EXTENSIONS=.jpg,.jpeg,.png,.webp,.pdf,.stl,.step,.stp,.obj,.3mf,.zip

# Rate limiting for public API endpoints
RATE_LIMIT_CHAT_WINDOW_SEC=60
RATE_LIMIT_CHAT_MAX=12
RATE_LIMIT_CONTACT_WINDOW_SEC=600
RATE_LIMIT_CONTACT_MAX=5
RATE_LIMIT_TRACK_WINDOW_SEC=60
RATE_LIMIT_TRACK_MAX=120
